#include <stdio.h>
#include <string.h>
#include "libft.h"
void	ft_bzero(void *s, size_t n)
{
	char *str;
	str = (char *)s;
	while (n--)
	{
		str[n] = 0;
	}
}
int main(void)
{
	char c[7];
	c = "abcdert";
	ft_bzero(c, 7);
	printf("%s", c);
	return 0;
}
